# Copy to .env.local for local dev. Paste the same keys into Vercel → Settings → Environment Variables (Production).
# Never commit real secrets. .env.local is gitignored.

# ─── Database (Supabase) ───────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── OpenAI ───────────────────────────────────────────────────────────
# platform.openai.com → API keys
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxx"

# ─── App URL ──────────────────────────────────────────────────────────
# Local: http://localhost:3000 (or :3001 if port in use)
# Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Auth ─────────────────────────────────────────────────────────────
# Generate AUTH_SECRET (32+ chars): openssl rand -base64 32
# Required on Vercel. Recommended locally.
AUTH_SECRET="replace-with-random-32-plus-character-string"
AUTH_URL="http://localhost:3000"

# Resend → API Keys + verified sender domain
# Optional locally — magic link prints to terminal without RESEND_API_KEY
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"
# Email you used to sign up at resend.com (sandbox testing only)
RESEND_ACCOUNT_EMAIL="you@gmail.com"
# Dev/testing only — Resend sandbox can email ONLY RESEND_ACCOUNT_EMAIL.
# To email teammates, verify YOUR domain at https://resend.com/domains then use:
# EMAIL_FROM="ReviewLens <hello@yourdomain.com>"
EMAIL_FROM="ReviewLens <onboarding@resend.dev>"

# ─── Upstash Redis (distributed rate limits) ──────────────────────────
# upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL="https://xxxx-xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxxxxxxxxxxxxxxx"

# ─── Inngest (background job queue) ───────────────────────────────────
# inngest.com → your app → Event Key + Signing Key
INNGEST_EVENT_KEY="xxxxxxxxxxxxxxxx"
INNGEST_SIGNING_KEY="signkey-prod-xxxxxxxxxxxxxxxx"

# LOCAL ONLY — do NOT set on Vercel. Run: npx inngest-cli dev -u http://localhost:3000/api/inngest
# INNGEST_DEV=1

# ─── Sentry (error monitoring, optional) ──────────────────────────────
# sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN="https://abc123@o123456.ingest.us.sentry.io/7890123"
NEXT_PUBLIC_SENTRY_DSN="https://abc123@o123456.ingest.us.sentry.io/7890123"
